# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Database (PostgreSQL / Neon)
DATABASE_URL=postgresql://user:password@localhost:5432/flowkyn

# JWT
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (OVH — port 587 + STARTTLS recommended)
SMTP_HOST=ssl0.ovh.ca
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@flowkyn.com
SMTP_PASS=your-smtp-password

# File Uploads — local directory (auto-created if missing)
UPLOADS_DIR=./flowkyn_uploads

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173

# CORS (optional — API allows all origins; used for logging only)
# CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Super Admin (comma-separated emails for admin.flowkyn.com access)
SUPER_ADMIN_EMAILS=admin@flowkyn.com

# Monitor Dashboard (leave empty for open access in dev)
MONITOR_SECRET=
